---
import type { HTMLAttributes } from "astro/types";
import Card from "./Card.astro";
import Icon from "./Icon.astro";
import "../pages/styles/global.css";
import NewsletterModal from "./NewsletterModal.astro";

interface Props extends HTMLAttributes<"div"> {}

const { class: className, ...props } = Astro.props;
---

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer
></script>

<style>
    dialog {
    position: fixed;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    border: solid pink 1px;
    padding: 15px;
  }
  dialog::backdrop {
    position: fixed;
    top: 0px;
    right: 0px;
    bottom: 0px;
    left: 0px;
  }
</style>

<Card>
  <div class="header-container" id="newsletter">
    <Icon
      type="lucide"
      name="message-square-code"
      width={24}
      height={24}
      class="glow-icon"
    />
    <h2>Newsletter</h2>
  </div>
  <div class="content-container">
    <div
      class="flex flex-wrap items-center w-full max-w-5xl p-5 mx-auto text-left"
    >
      <div class="flex-1 w-full mb-5 md:mb-0 md:pr-5 lg:pr-10 md:w-1/2">
        <h3 class="mb-2 text-2xl font-bold text-gray-200">
          Suscribete a la Newsletter
        </h3>
        <p class="text-white-500 dark:text-white-400">
          Proporcina tu email para mandarte notificaciones sobre <b>eventos</b>, <b
            >retos</b
          >, <b>posts</b> y mucho más <em>(nada de spam)</em> sobre la comunidad de
          Hola Developers! Y si añades tu usuario de <a
            target="_blank"
            href="https://discord.gg/wkvYgfGBWW">Discord</a
          > tendrás un <b>canal exclusivo</b> donde me podrás <b
            >preguntar lo que quieras</b
          > sobre programación web.
        </p>
      </div>
      <div class="w-full px-1 md:flex-0 md:w-auto lg:w-1/2">
        <p id="error" style="visibility: hidden;" class="text-red-400">
          Por favor, completa el captcha antes de continuar.
        </p>
        <form id="contact-form">
          <input type="hidden" name="tags" value="earlyaccess" />
          <div class="flex flex-col sm:flex-row">
            <input
              type="text"
              id="discord"
              name="discord"
              placeholder="Discord (opcional)"
              class="flex-1 px-3 py-2 mt-5 placeholder-gray-300 border border-gray-300 rounded-sm focus:outline-none focus:ring focus:ring-indigo-100 focus:border-indigo-300 dark:[#121212] dark:text-white dark:placeholder-gray-400 dark:border-[#fabfad] dark:focus:ring-gray-900 dark:focus:border-[#fc8e6d]"
            />
          </div>
          <div class="flex flex-col sm:flex-row pt-4">
            <input
              type="email"
              id="email"
              name="email"
              placeholder="Email*"
              class="flex-1 px-3 py-2 placeholder-gray-300 border border-gray-300 rounded-sm focus:outline-none focus:ring focus:ring-indigo-100 focus:border-indigo-300 dark:[#121212] dark:text-white dark:placeholder-gray-400 dark:border-[#fabfad] dark:focus:ring-gray-900 dark:focus:border-[#fc8e6d]"
              required
            />
          </div>
          <div class="mt-5">
            <small
              ><label for="terms-conditions">
                <input type="checkbox" id="terms-conditions" required /> Acepto los
                <a id="terms-text">términos y condiciones.</a>
              </label></small
            >
          </div>
          <div
            class="cf-turnstile mt-5"
            data-sitekey="0x4AAAAAACnYU9BDMorzopND"
            data-theme="dark"
            data-size="flexible"
            data-callback="onTurnstileSuccess"
            data-error-callback="onTurnstileError"
            data-expired-callback="onTurnstileExpired"
          >
          </div>
          <div class="flex flex-col sm:flex-row pt-4">
            <div class="relative m-auto group">
              <div
                id="submit-glow"
                class="absolute transition-all duration-1000 -inset-px bg-linear-to-r from-[#ff7b72] via-[#ffa657] to-[#f48866] rounded-xl blur-lg animate-tilt opacity-70 group-hover:opacity-100 group-hover:-inset-1 group-hover:duration-200 group-has-disabled:opacity-0"
              >
              </div>
              <button
                id="submit-btn"
                type="submit"
                class="relative inline-flex flex-1 px-3 py-2 text-white text-lg bg-gray-900 rounded-sm sm:mt-0 sm:w-auto whitespace-nowrap dark:bg-gray-900 disabled:opacity-50 disabled:cursor-not-allowed"
                disabled
              >
                Suscribirse
              </button>
            </div>
          </div>
        </form>
      </div>
      <input type="hidden" name="form-name" value="newsletter" />
    </div>
  </div>
</Card>
<NewsletterModal />

<dialog id="modal-terms">
  <small>
    Información básica sobre protección de datos: El responsable es Juan C. Peña.
    La finalidad es el envío de noticias relacionadas con el blog y soporte en Discord (opcional). No se cederán
    datos a terceros salvo obligación legal. Puedes ejercer tus derechos de
    acceso, rectificación y supresión enviando un correo a newsletter@holadevolopers.blog
  </small>
  <br>
  <button
    onclick="document.getElementById('modal-terms').close()"
    class="mt-4 px-4 py-2 bg-gray-800 text-white rounded hover:bg-gray-700"
  >
    Vale :)
  </button>
</dialog>

<script>
  // 1. Definimos las funciones en el objeto window para que Turnstile las encuentre
  (window as any).onTurnstileSuccess = function (token: string) {
    const btn = document.getElementById("submit-btn") as HTMLButtonElement;
    if (btn) btn.disabled = false;
  };

  (window as any).onTurnstileError = function () {
    const btn = document.getElementById("submit-btn") as HTMLButtonElement;
    if (btn) btn.disabled = true;
  };

  (window as any).onTurnstileExpired = function () {
    const btn = document.getElementById("submit-btn") as HTMLButtonElement;
    if (btn) btn.disabled = true;
  };

  document.addEventListener("DOMContentLoaded", () => {
    const errorMsg = document.getElementById("error") as HTMLParagraphElement;
    const form = document.getElementById("contact-form") as HTMLFormElement;
    const termsText = document.getElementById("terms-text");
    termsText?.addEventListener("click", () => {
      const modalTerms = document.getElementById(
        "modal-terms",
      ) as HTMLDialogElement;
      modalTerms.showModal();
    });

    if (form) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();

        const formData = new FormData(form);

        const turnstileResponse = formData.get("cf-turnstile-response");

        // // 2. Validación extra: Si no hay token, no enviamos nada
        if (!turnstileResponse) {
          errorMsg.style.visibility = "visible";
          errorMsg.innerText =
            "Por favor, completa el captcha antes de continuar.";
          // alert("Por favor, completa el captcha antes de continuar.");
          return;
        }

        const submitButton = form.querySelector(
          'button[type="submit"]',
        ) as HTMLButtonElement;
        const originalText = submitButton?.textContent || "Suscribirse";

        try {
          submitButton.disabled = true;
          submitButton.textContent = "Enviando...";
          const termsCheck = document.getElementById('terms-conditions') as HTMLInputElement

          // Capturamos los datos reales
          const payload = {
            email: formData.get("email"),
            discord: formData.get("discord"),
            terms: termsCheck.checked,
            // Turnstile añade automáticamente un input llamado 'cf-turnstile-response'
            turnstileToken: formData.get("cf-turnstile-response"),
          };

          const response = await fetch("/api/newsletter", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify(payload),
          });

          const result = await response.json();

          // Si es exitoso, muestra un modal
          const modal = document.getElementById(
            "modal-newsletter",
          ) as HTMLDialogElement;
          if (result.success) {
            modal.dispatchEvent(
              // Dispatch custom event
              new CustomEvent("open-modal", {
                detail: { existe: result.existe },
              }),
            );
          } else {
            throw new Error(result.error || "Error desconocido");
          }
        } catch (error) {
          console.error("Error:", error);
          // alert("Error al suscribirse. Intenta nuevamente.");
          errorMsg.style.visibility = "visible";
          errorMsg.innerText =
            "Error al suscribirse. Intenta nuevamente.";
          submitButton.disabled = false;
          submitButton.textContent = originalText;
        }
      });
    }
  });
</script>
