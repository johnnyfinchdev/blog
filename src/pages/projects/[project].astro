---
import "../../styles/article.css";
import Card from "../../components/Card.astro";
import Layout from "../../layouts/Layout.astro";
import type { GetStaticPaths } from "astro";
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import ImageGlow from "../../components/ImageGlow.astro";
import Icon from "../../components/Icon.astro";

import { marked } from 'marked';

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;

export const getStaticPaths = (async () => {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { project: project.id },
    props: { project },
  }));
}) satisfies GetStaticPaths;

// Lógica para obtener el README remoto
let remoteContent = "";
const repo = project.data.gitData;

if (repo) {
  try {
    // Intentamos obtener el README de la rama 'main' (o 'master' si falla)
    const response = await fetch(`https://raw.githubusercontent.com/${repo}/main/README.md`);
    
    if (response.ok) {
      const markdown = await response.text();
      // Parseamos el markdown a HTML
      remoteContent = await marked.parse(markdown);
    } else {
      // Intento alternativo por si la rama es 'master'
      const fallbackResponse = await fetch(`https://raw.githubusercontent.com/${repo}/master/README.md`);
      if (fallbackResponse.ok) {
        const markdown = await fallbackResponse.text();
        remoteContent = await marked.parse(markdown);
      }
    }
  } catch (e) {
    console.error(`Error cargando el README para ${repo}:`, e);
  }
}
---

<Layout
  title={project.data.title}
  description={project.data.description}
  image={project.data.image}
  article={{
    createdAt: project.data.date,
  }}
>
  <div class="left" slot="left">
    <Card class="toc-card">
      <h2 class="no-mt">Info</h2>
      <ul class="overview-list">
        {
          project.data.info.map((info: { icon: { type: string; name: any; }; text: unknown; }) => {
            const Tag = repo ? "a" : "div";
            return (
              <li>
                <Tag href={`https://github.com/${repo}`} class="project-info-item" target="_blank">
                  <Icon
                    type={info.icon.type as "lucide" | "simple-icons"}
                    name={info.icon.name as any}
                    width={24}
                    height={24}
                    class="glow-icon"
                  />
                  <span>{info.text}</span>
                </Tag>
              </li>
            );
          })
        }
      </ul>
    </Card>
  </div>
  <article slot="right" data-pagefind-body>
    <Card>
      <div class="article-header" id="_top" data-pagefind-ignore>
        {
          project.data.image && (
            <ImageGlow
              quality={100}
              class="article-image"
              src={project.data.image}
              alt={project.data.title}
            />
          )
        }
        <div class="header">
          <div>
            <h1 class="no-mt article-h1">{project.data.title}</h1>
          </div>
          <div class="article-info">
            <span>{project.data.date.toLocaleDateString()}</span>
          </div>
        </div>
      </div>

      {/* Renderizamos el contenido remoto inyectando el HTML */}
      <div class="markdown-content">
        {remoteContent ? (
          <div class="markdown-repository" set:html={remoteContent} />
        ) : (
          <p>No se pudo cargar el contenido del repositorio.</p>
        )}
      </div>

      <hr class="end-of-article" />
      <a href="/projects" class="block-link" data-pagefind-ignore
        >← Volver a los proyectos</a
      >
    </Card>
  </article>
</Layout>

<style>
  .project-info-item {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .markdown-content :global(pre) {
    background: #1a1a1a;
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
  }
</style>